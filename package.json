{
  "name": "verifield-nexus",
  "version": "1.0.0",
  "description": "Verification Infrastructure for Real-World Climate Assets on Solana",
  "main": "index.js",
  "scripts": {
    "build": "npm run build --prefix dashboard",
    "dashboard:dev": "npm run dev --prefix dashboard",
    "dashboard:build": "npm run build --prefix dashboard",
    "dashboard:start": "npm run start --prefix dashboard",
    "sdk:build": "tsc --project sdk/tsconfig.json",
